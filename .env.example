# =============================================
# BASE DE DONNÉES POSTGRESQL
# =============================================
# Hôte du service PostgreSQL (nom du service Docker)
DATABASE_HOST=postgres
# Port PostgreSQL par défaut
DATABASE_PORT=5432
# Utilisateur de la base de données
DATABASE_USER=saasrdv
# Mot de passe de la base de données (à changer en production)
DATABASE_PASSWORD=saasrdv_dev
# Nom de la base de données
DATABASE_NAME=saasrdv

# =============================================
# AUTHENTIFICATION GOOGLE OAUTH2
# Créer les credentials sur : https://console.cloud.google.com/
# =============================================
# Client ID de votre application Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
# Client Secret de votre application Google OAuth
GOOGLE_CLIENT_SECRET=your-google-client-secret
# URL de callback après authentification Google
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# =============================================
# JWT (JSON Web Token)
# =============================================
# Clé secrète pour signer les tokens JWT (générer une valeur forte en production)
JWT_SECRET=super-secret-jwt-key-change-in-production

# =============================================
# STRIPE (Paiements)
# Créer un compte sur : https://stripe.com/
# =============================================
# Clé secrète Stripe (sk_test_... pour les tests, sk_live_... pour la production)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Secret du webhook Stripe (obtenu dans le dashboard Stripe > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
# ID du prix Stripe pour le plan Pro
STRIPE_PRO_PRICE_ID=price_pro_placeholder
# ID du prix Stripe pour le plan Business
STRIPE_BUSINESS_PRICE_ID=price_business_placeholder

# =============================================
# URLS
# =============================================
# URL du frontend (utilisée pour les redirections CORS et OAuth)
FRONTEND_URL=http://localhost:3000
# Port d'écoute du backend NestJS
PORT=3001
